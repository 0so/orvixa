# ─────────────────────────────────────────────────────────────────────────
# ORVIXA — Phase 2 / Milestone 1-2 configuration
# Copy to `.env`. Defaults work as-is. Public Binance market data needs no key.
# ─────────────────────────────────────────────────────────────────────────

# Feed source: "sim" (offline, deterministic) | "binance" (live WS + REST)
FEED=binance

# Binance public endpoints (market data only — no API key required)
BINANCE_WS_BASE=wss://stream.binance.com:9443
BINANCE_REST_BASE=https://api.binance.com

# Always-tracked core symbols (Tier 0)
CORE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Seed set for M1 (Tier 1 is made dynamic in M3). Note Binance's 1000x meme pairs.
SEED_SYMBOLS=BNBUSDT,XRPUSDT,AVAXUSDT,LINKUSDT,DOGEUSDT,1000PEPEUSDT,1000SHIBUSDT,WIFUSDT

# Candle interval and reconnect backfill depth
KLINE_INTERVAL=1m
BACKFILL_LIMIT=5

# Logging
LOG_LEVEL=INFO

# Web/API (Phase 2). APP_ENV=production (the default) enforces a real,
# non-default API_KEY and forbids wildcard CORS at startup. Set
# APP_ENV=development for local work, where API_KEY may be left empty
# (disables auth) and CORS_ORIGINS may include "*".
# API_KEY guards the read-only endpoints via the X-API-Key header.
# CORS_ORIGINS is a comma-separated list of allowed frontend origins.
# DAEMON_INTERVAL_SECONDS is the restart/poll interval for the looped
# ingest/analytics daemons.
APP_ENV=development
API_KEY=
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_SIGNALS_LIMIT=50
DAEMON_INTERVAL_SECONDS=5.0

# Persistence (M2) — host names match docker-compose services; REDIS_URL used from M5
# In production (APP_ENV=production), POSTGRES_DSN/REDIS_URL must NOT contain
# the default "orvixa:orvixa" credentials. For docker-compose.prod.yml, also
# set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB and REDIS_PASSWORD below
# and update these DSNs to match.
POSTGRES_DSN=postgresql://orvixa:orvixa@postgres:5432/orvixa
REDIS_URL=redis://redis:6379/0

# Required by docker-compose.prod.yml only:
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=orvixa
# REDIS_PASSWORD=

# asyncpg pool sizing
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# Candle batch writer: flush on whichever limit is hit first
CANDLE_BATCH_MAX_SIZE=200
CANDLE_BATCH_INTERVAL_SECONDS=2.0

# Simulator tuning (dev only) — seconds between simulated 1m candles
SIM_CANDLE_SECONDS=3.0
